{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "*.ts",
    "types/*.ts",
    "lib/*.ts",
    "hooks/*.ts",
    "tools/*.ts",
    "commands/*.ts"
  ],
  "exclude": ["node_modules", "tests"]
}
